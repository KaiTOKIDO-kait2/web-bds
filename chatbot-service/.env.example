# Sao chép thành .env và chỉnh sửa

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=realestatephp_new

PUBLIC_BASE_PATH=/Real-Estate-website-in-PHP-main

INTERNAL_SECRET=

DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

MAX_USER_TEXT_LEN=2000
MAX_PROPERTIES_RETURN=8
MAX_RANKING_CANDIDATES=80
MAX_LAST_PIDS=50
RECOMMENDATION_RETURN=8

EMBEDDING_ENABLED=false
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_THRESHOLD=0.55

CORS_ORIGINS=*
